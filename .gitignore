cordelia/config/sonvs_anal.json
cordelia/config/GEN.json
cordelia/config/ROUTING.json
cordelia/config/SCALA.json
cordelia/config/tokens.json

# Rendered audio outputs
_score/**/*.wav
_score/**/*.flac
_score/**/*.aif
_score/**/*.aiff
